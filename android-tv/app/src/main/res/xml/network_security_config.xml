<?xml version="1.0" encoding="utf-8"?>
<!--
  Production: HTTPS only. The TVs only ever talk to your-domain.com over TLS.

  Development: if you need to point a TV at a laptop running `next dev` over
  the LAN, add the laptop's IP as a domain-config exception below. Example:

    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.1.42</domain>
    </domain-config>
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!-- Emulador Android: 10.0.2.2 = tu PC (host machine).
         LDPlayer/Genymotion: usa 10.0.3.2 en su lugar. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">10.0.3.2</domain>
    </domain-config>
</network-security-config>
